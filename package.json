{
  "name": "web-search-mcp",
  "version": "0.1.0",
  "description": "Best-in-class web search MCP server with multi-provider retrieval and extraction.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "web-search-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "publishConfig": {
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts --port 8080",
    "dev:http": "tsx src/index.ts --port 8080",
    "dev:stdio": "tsx src/index.ts --stdio",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "npm run lint:types && npm run lint:eslint && npm run format:check",
    "lint:types": "tsc -p tsconfig.json --noEmit",
    "lint:eslint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "compare": "tsx src/cli/compare.ts",
    "eval": "tsx src/cli/eval.ts",
    "inspector": "npx @modelcontextprotocol/inspector tsx src/index.ts",
    "inspector:stdio": "npx @modelcontextprotocol/inspector tsx src/index.ts --stdio",
    "start": "node dist/index.js",
    "start:stdio": "node dist/index.js --stdio",
    "audit:prod": "npm audit --omit=dev"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "web-search",
    "agent"
  ],
  "author": "cforey",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.5",
    "@mozilla/readability": "^0.6.0",
    "@opentelemetry/api": "^1.9.1",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^17.4.2",
    "franc": "^6.2.0",
    "ioredis": "^5.10.1",
    "jsdom": "^26.1.0",
    "lru-cache": "^11.2.2",
    "p-queue": "^8.1.0",
    "pdf-parse": "^1.1.1",
    "prom-client": "^15.1.3",
    "rss-parser": "^3.13.0",
    "turndown": "^7.2.0",
    "undici": "^7.16.0",
    "youtube-transcript": "^1.2.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.15.18",
    "@types/pdf-parse": "^1.1.5",
    "@types/turndown": "^5.0.6",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^10.3.0",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-security": "^4.0.0",
    "prettier": "^3.8.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^2.1.9"
  },
  "optionalDependencies": {
    "playwright-core": "^1.54.1"
  }
}
